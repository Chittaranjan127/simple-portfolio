{"arguments":{"script":"(async () => {\n  const start = Date.now();\n  const hm = document.getElementById('ghHeatmap');\n  while ((!hm || hm.children.length < 300) && Date.now() - start < 9000) {\n    await new Promise(r => setTimeout(r, 200));\n  }\n  // hide splash so screenshot shows content\n  const sp = document.getElementById('splash'); if (sp) sp.style.display = 'none';\n  const gh = document.getElementById('github'); if (gh) gh.scrollIntoView();\n  const cells = hm ? [...hm.children] : [];\n  const levels = [0,1,2,3,4].map(L => cells.filter(c => (+c.dataset.level||0) === L).length);\n  return {\n    cellCount: cells.length,\n    nonZero: cells.filter(c => (+c.dataset.level||0) > 0).length,\n    levels,\n    contribs: (document.getElementById('ghContribs')||{}).textContent,\n    repos: (document.getElementById('ghRepos')||{}).textContent,\n    first: cells[0] && cells[0].dataset.date,\n    last: cells[cells.length-1] && cells[cells.length-1].dataset.date,\n    sampleTitle: cells[cells.length-1] && cells[cells.length-1].title\n  };\n})()"},"level":"debug","message":"Tool call received","service":"mcp-puppeteer","timestamp":"2026-07-01 17:18:54.257","tool":"puppeteer_evaluate"}
